model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["dim_champion","dim_date","dim_match","dim_rank","dim_summoner","dim_team","fact_participant_performance","fact_rank_snapshot","fact_team_objectives","fact_timeline_events","fact_timeline_frames","mart_champion_daily_performance","mart_player_daily_performance","mart_rank_daily_summary","mart_role_daily_performance","mart_team_objective_daily_summary"]

annotation PBI_ProTooling = ["DevMode"]

ref table dim_champion
ref table dim_date
ref table dim_match
ref table dim_rank
ref table dim_summoner
ref table dim_team
ref table fact_participant_performance
ref table fact_rank_snapshot
ref table fact_team_objectives
ref table fact_timeline_events
ref table fact_timeline_frames
ref table mart_champion_daily_performance
ref table mart_player_daily_performance
