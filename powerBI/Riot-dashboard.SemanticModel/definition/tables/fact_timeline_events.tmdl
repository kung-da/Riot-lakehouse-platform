table fact_timeline_events
	lineageTag: f4d1faae-ebca-4678-8c7f-eafc5b0a30dd

	measure 'Timeline Frames' = COUNTROWS('fact_timeline_frames')
		lineageTag: 5b6fd7b2-eade-439d-9a38-ae28c01d574c

	measure 'Timeline Frame Event Count' = SUM('fact_timeline_frames'[event_count])
		lineageTag: 99d5ec35-38ed-4a75-bb6b-4e7a13d60d7e

	measure 'Timeline Events' = COUNTROWS('fact_timeline_events')
		lineageTag: c0d88c0a-ea33-4699-a2a2-e21b555b9f0e

	measure 'Timeline Event Match Count' = DISTINCTCOUNT('fact_timeline_events'[match_id])
		lineageTag: 2778dfaf-21ec-4129-9467-8d4d2d756646

	measure 'Avg Events Per Match' = DIVIDE([Timeline Events], [Timeline Event Match Count])
		lineageTag: 31cc54d9-cc91-41a3-b716-5f304d38abfd

	measure 'Avg Events Per Frame' = DIVIDE([Timeline Events], [Timeline Frames])
		lineageTag: a2a69316-b0e1-493b-833d-e8fc2f77fc2d

	measure 'Average Event Minute' = DIVIDE(AVERAGE('fact_timeline_events'[event_timestamp]), 60000)
		lineageTag: fff38a72-4189-42cc-ae6e-1d0eaf9807dc

	measure 'Kill Events' =
			CALCULATE(
			    [Timeline Events],
			    'fact_timeline_events'[event_type] = "CHAMPION_KILL"
			)
		lineageTag: fd56d079-c339-4ff0-975a-e272880a9808

	measure 'Elite Monster Events' =
			CALCULATE(
			    [Timeline Events],
			    'fact_timeline_events'[event_type] = "ELITE_MONSTER_KILL"
			)
		lineageTag: 30f8f492-c810-435a-8412-5db65651798d

	measure 'Building Events' =
			CALCULATE(
			    [Timeline Events],
			    'fact_timeline_events'[event_type] = "BUILDING_KILL"
			)
		lineageTag: 5fed118b-e161-4fd6-9e6f-d0e8dd325a15

	measure 'Dragon Events' =
			CALCULATE(
			    [Timeline Events],
			    'fact_timeline_events'[monster_type] = "DRAGON"
			)
		lineageTag: 412e3794-8602-4026-8e59-99d86de19be6

	measure 'Baron Events' =
			CALCULATE(
			    [Timeline Events],
			    'fact_timeline_events'[monster_type] = "BARON_NASHOR"
			)
		lineageTag: 33b59250-fa41-44c4-a414-71c2a2af2f49

	measure 'Rift Herald Events' =
			CALCULATE(
			    [Timeline Events],
			    'fact_timeline_events'[monster_type] = "RIFTHERALD"
			)
		lineageTag: a7458eb9-0061-4c71-a0bc-f9d323556a4a

	measure 'Tower Events' =
			CALCULATE(
			    [Timeline Events],
			    'fact_timeline_events'[building_type] = "TOWER_BUILDING"
			)
		lineageTag: 8c9f72d3-2380-4959-b0e9-a774c4185dba

	measure 'Inhibitor Events' =
			CALCULATE(
			    [Timeline Events],
			    'fact_timeline_events'[building_type] = "INHIBITOR_BUILDING"
			)
		lineageTag: 54148e65-ab9e-4e96-8ff1-1d1f9c88e8f4

	measure 'Events Before 15 Minutes' =
			CALCULATE(
			    [Timeline Events],
			    'fact_timeline_events'[event_timestamp] <= 900000
			)
		lineageTag: 458ef7a0-f806-4d48-b1b2-a5ab78c00980

	measure 'Kills Before 15 Minutes' =
			CALCULATE(
			    [Kill Events],
			    'fact_timeline_events'[event_timestamp] <= 900000
			)
		lineageTag: 298d5a6e-847e-48d2-91d8-931f0036fa2f

