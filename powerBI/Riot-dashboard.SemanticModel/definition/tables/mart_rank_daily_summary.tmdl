		lineageTag: b936b557-5fbe-4b14-9dc5-f90954f3b178

	measure 'Rank Snapshot Unique Players' =
			VAR RankFilter =
			    SUMMARIZE(
			        'dim_rank',
			        'dim_rank'[queue],
			        'dim_rank'[tier],
			        'dim_rank'[rank]
			    )
			RETURN
			    CALCULATE(
			        DISTINCTCOUNT('fact_rank_snapshot'[puuid]),
			        TREATAS(
			            RankFilter,
			            'fact_rank_snapshot'[queue],
			            'fact_rank_snapshot'[tier],
			            'fact_rank_snapshot'[rank]
			        )
			    )
		lineageTag: 7604004f-259d-4225-a938-b7a0cd89c98e

	measure 'Average League Points' =
			VAR RankFilter =
			    SUMMARIZE(
			        'dim_rank',
			        'dim_rank'[queue],
			        'dim_rank'[tier],
			        'dim_rank'[rank]
			    )
			RETURN
			    CALCULATE(
			        AVERAGE('fact_rank_snapshot'[league_points]),
			        TREATAS(
			            RankFilter,
			            'fact_rank_snapshot'[queue],
			            'fact_rank_snapshot'[tier],
			            'fact_rank_snapshot'[rank]
			        )
			    )
		lineageTag: e1f19588-3e10-4458-b0e9-775bed255f71

	measure 'Rank Snapshot Wins' =
			VAR RankFilter =
			    SUMMARIZE(
			        'dim_rank',
			        'dim_rank'[queue],
			        'dim_rank'[tier],
			        'dim_rank'[rank]
			    )
			RETURN
			    CALCULATE(
			        SUM('fact_rank_snapshot'[wins]),
			        TREATAS(
			            RankFilter,
			            'fact_rank_snapshot'[queue],
			            'fact_rank_snapshot'[tier],
			            'fact_rank_snapshot'[rank]
			        )
			    )
		lineageTag: 7b7fae5f-e4e7-45cd-8c05-02c5a9a0f7b2

	measure 'Rank Snapshot Losses' =
			VAR RankFilter =
			    SUMMARIZE(
			        'dim_rank',
			        'dim_rank'[queue],
			        'dim_rank'[tier],
			        'dim_rank'[rank]
			    )
			RETURN
			    CALCULATE(
			        SUM('fact_rank_snapshot'[losses]),
			        TREATAS(
			            RankFilter,
			            'fact_rank_snapshot'[queue],
			            'fact_rank_snapshot'[tier],
			            'fact_rank_snapshot'[rank]
			        )
			    )
		lineageTag: d1c8874e-a161-4820-8059-0a925050820b

	measure 'Rank Snapshot Win Rate' = DIVIDE([Rank Snapshot Wins], [Rank Snapshot Wins] + [Rank Snapshot Losses])
		lineageTag: c5c671ad-bc94-4c2c-8ab8-d5d30970df58

	measure 'Is Hot Streak Count' =
			CALCULATE(
			    [Rank Snapshot Unique Players],
			    'fact_rank_snapshot'[hot_streak] = TRUE()
			)
		lineageTag: 8263b3f4-82a4-4994-a97e-c2c919f735ac

	measure 'Is Inactive Count' =
			CALCULATE(
			    [Rank Snapshot Unique Players],
			    'fact_rank_snapshot'[inactive] = TRUE()
			)
		lineageTag: a23a233b-6c46-4171-9693-7dae90717288

