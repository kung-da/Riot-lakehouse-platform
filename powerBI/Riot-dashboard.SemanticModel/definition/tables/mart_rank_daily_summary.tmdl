table mart_rank_daily_summary
	lineageTag: fb8b185d-3d1f-4891-9905-991c98f90f16

	measure 'Rank Summary Players' =
			VAR RankFilter =
			    SUMMARIZE(
			        'dim_rank',
			        'dim_rank'[queue],
			        'dim_rank'[tier],
			        'dim_rank'[rank]
			    )
			RETURN
			    CALCULATE(
			        SUM('mart_rank_daily_summary'[players]),
			        TREATAS(
			            RankFilter,
			            'mart_rank_daily_summary'[queue],
			            'mart_rank_daily_summary'[tier],
			            'mart_rank_daily_summary'[rank]
			        )
			    )
		lineageTag: d7bfd0e9-1b71-4887-8dd7-75258fed4cd2

	measure 'Rank Population Share' =
			DIVIDE(
			    [Rank Summary Players],
			    CALCULATE([Rank Summary Players], ALL('dim_rank'))
			)
		lineageTag: cdec7874-2229-453a-bb2d-6c6f6655ee8d

	measure 'Rank Avg League Points' =
			VAR RankFilter =
			    SUMMARIZE(
			        'dim_rank',
			        'dim_rank'[queue],
			        'dim_rank'[tier],
			        'dim_rank'[rank]
			    )
			RETURN
			    CALCULATE(
			        DIVIDE(
			            SUMX(
			                'mart_rank_daily_summary',
			                'mart_rank_daily_summary'[avg_league_points]
			                    * 'mart_rank_daily_summary'[players]
			            ),
			            SUM('mart_rank_daily_summary'[players])
			        ),
			        TREATAS(
			            RankFilter,
			            'mart_rank_daily_summary'[queue],
			            'mart_rank_daily_summary'[tier],
			            'mart_rank_daily_summary'[rank]
			        )
			    )
		lineageTag: a219a1a0-3f03-468a-ac98-327fa0b00d04

	measure 'Rank Avg Win Rate' =
			VAR RankFilter =
			    SUMMARIZE(
			        'dim_rank',
			        'dim_rank'[queue],
			        'dim_rank'[tier],
			        'dim_rank'[rank]
			    )
			RETURN
			    CALCULATE(
			        DIVIDE(
			            SUMX(
			                'mart_rank_daily_summary',
			                'mart_rank_daily_summary'[avg_win_rate]
			                    * 'mart_rank_daily_summary'[players]
			            ),
			            SUM('mart_rank_daily_summary'[players])
			        ),
			        TREATAS(
			            RankFilter,
			            'mart_rank_daily_summary'[queue],
			            'mart_rank_daily_summary'[tier],
			            'mart_rank_daily_summary'[rank]
			        )
			    )
		lineageTag: 29f1d2fd-cc79-42b9-a4e7-4be9ebdb322a

