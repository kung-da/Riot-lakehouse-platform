			)
		lineageTag: 4f5999b3-de2b-4759-93f0-d9cb660c38ce

	measure 'Avg Tower Kills' =
			DIVIDE(
			    SUMX(
			        'mart_team_objective_daily_summary',
			        'mart_team_objective_daily_summary'[avg_tower_kills]
			            * 'mart_team_objective_daily_summary'[games_played]
			    ),
			    [Team Objective Games]
			)
		lineageTag: 8645b571-58a9-4703-b9e9-e4009ca1668d

	measure 'Avg Inhibitor Kills' =
			DIVIDE(
			    SUMX(
			        'mart_team_objective_daily_summary',
			        'mart_team_objective_daily_summary'[avg_inhibitor_kills]
			            * 'mart_team_objective_daily_summary'[games_played]
			    ),
			    [Team Objective Games]
			)
		lineageTag: a23ae7bc-4374-4ecc-a81a-0d7b03606c68

	measure 'Avg Champion Kills' =
			DIVIDE(
			    SUMX(
			        'mart_team_objective_daily_summary',
			        'mart_team_objective_daily_summary'[avg_champion_kills]
