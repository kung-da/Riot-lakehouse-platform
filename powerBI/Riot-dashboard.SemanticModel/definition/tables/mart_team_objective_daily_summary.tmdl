table mart_team_objective_daily_summary
	lineageTag: fec8f66a-bc61-4443-a93f-8ca91d0de0ee

	measure 'Team Objective Games' = SUM('mart_team_objective_daily_summary'[games_played])
		lineageTag: d8c2e5f3-5d00-471c-b4b6-2eb603c048b2

	measure 'Team Wins' = SUM('mart_team_objective_daily_summary'[wins])
		lineageTag: 73640bc8-246a-40ec-bad5-062ecc670872

	measure 'Team Losses' = SUM('mart_team_objective_daily_summary'[losses])
		lineageTag: ab700775-a2a5-4416-b935-70740f58abf7

	measure 'Team Win Rate' = DIVIDE([Team Wins], [Team Objective Games])
		lineageTag: 95a460b1-b5bd-4a3c-8b35-0d0e6f4683b7

	measure 'Total Objective Score' = SUM('fact_team_objectives'[objective_score])
		lineageTag: c0b2d57a-5bcf-4e0f-b818-b4d0a7160b3e

	measure 'Team Objective Score' = [Total Objective Score]
		lineageTag: 1ef42eb5-f026-4def-bda2-f1f2c2564b9e

	measure 'Objective Rows' = COUNTROWS('fact_team_objectives')
		lineageTag: c5d9ec6c-466f-4dfa-9881-9bbc9d12f0fd

	measure 'Avg Objectives Per Team Game' = DIVIDE([Total Objective Score], [Objective Rows])
		lineageTag: 62aedfaf-2022-4ae2-823e-48b86c5cdbde

	measure 'Avg Objective Score' =
			DIVIDE(
			    SUMX(
			        'mart_team_objective_daily_summary',
			        'mart_team_objective_daily_summary'[avg_objective_score]
			            * 'mart_team_objective_daily_summary'[games_played]
			    ),
			    [Team Objective Games]
			)
		lineageTag: c53b13c3-3ffa-42e5-a7fd-052ca100b568

	measure 'Objective Control Share' =
			DIVIDE(
			    [Total Objective Score],
			    CALCULATE([Total Objective Score], ALL('dim_team'))
			)
		lineageTag: b3edf207-029c-49b5-874e-e39366c15c9c

	measure 'Total Baron Kills' = SUM('fact_team_objectives'[baron_kills])
		lineageTag: 0fb6983b-e7a4-48ca-8ae5-70fd6a3c8736

	measure 'Total Dragon Kills' = SUM('fact_team_objectives'[dragon_kills])
		lineageTag: e101fb99-605d-4e85-b238-6ca2831a579c

	measure 'Total Rift Herald Kills' = SUM('fact_team_objectives'[rift_herald_kills])
		lineageTag: a5c54a7c-9be6-4a8d-867d-1702af3bfce7

	measure 'Total Tower Kills' = SUM('fact_team_objectives'[tower_kills])
		lineageTag: 528604f4-6a64-4feb-9c0f-945fe51bb007

	measure 'Total Inhibitor Kills' = SUM('fact_team_objectives'[inhibitor_kills])
		lineageTag: 1585ad2a-52e5-4f81-8db8-43783bef50e2

	measure 'Total Champion Kills' = SUM('fact_team_objectives'[champion_kills])
		lineageTag: 38c54216-639f-4a52-8e61-4cdf4b6a6c0f

	measure 'Avg Baron Kills' =
			DIVIDE(
			    SUMX(
			        'mart_team_objective_daily_summary',
			        'mart_team_objective_daily_summary'[avg_baron_kills]
			            * 'mart_team_objective_daily_summary'[games_played]
			    ),
			    [Team Objective Games]
			)
		lineageTag: bf14377a-1931-4f77-9405-a8a35aff47b8

	measure 'Avg Dragon Kills' =
			DIVIDE(
			    SUMX(
			        'mart_team_objective_daily_summary',
