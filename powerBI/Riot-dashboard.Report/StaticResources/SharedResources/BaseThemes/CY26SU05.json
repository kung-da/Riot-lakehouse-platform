{
  "name": "Riot Lakehouse Esports Dark",
  "dataColors": [
    "#D13639",
    "#C89B3C",
    "#00C2FF",
    "#8A5CF6",
    "#2FE6A6",
    "#F97316",
    "#7DD3FC",
    "#E879F9",
    "#94A3B8",
    "#F8FAFC"
  ],
  "background": "#05070D",
  "foreground": "#F2F4F8",
  "tableAccent": "#C89B3C",
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 18,
      "color": "#F8FAFC"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 12,
      "color": "#E6EDF7"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#A8B3C7"
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 28,
      "color": "#F8FAFC"
    }
  },
  "visualStyles": {
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#05070D"
              }
            },
            "transparency": 0
          }
        ]
      }
    },
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#0B1020"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#1F2A44"
              }
            },
            "radius": 4
          }
        ],
        "dropShadow": [
          {
            "show": false
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#E6EDF7"
              }
            },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold",
            "alignment": "left"
          }
        ],
        "legend": [
          {
            "show": true,
            "labelColor": {
              "solid": {
                "color": "#A8B3C7"
              }
            },
            "fontSize": 9,
            "fontFamily": "Segoe UI"
          }
        ],
        "categoryAxis": [
          {
            "show": true,
            "labelColor": {
              "solid": {
                "color": "#A8B3C7"
              }
            },
            "fontSize": 9,
            "fontFamily": "Segoe UI",
            "gridlineColor": {
              "solid": {
                "color": "#1F2A44"
              }
            }
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "labelColor": {
              "solid": {
                "color": "#A8B3C7"
              }
            },
            "fontSize": 9,
            "fontFamily": "Segoe UI",
            "gridlineColor": {
              "solid": {
                "color": "#1F2A44"
              }
            }
          }
        ],
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#F2F4F8"
              }
            },
            "fontSize": 9,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "card": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#0F172A"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#C89B3C"
              }
            },
            "radius": 4
          }
        ],
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#F8FAFC"
              }
            },
            "fontSize": 24,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#A8B3C7"
              }
            },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#0B1020"
              }
            },
            "transparency": 0
          }
        ],
        "items": [
          {
            "fontColor": {
              "solid": {
                "color": "#E6EDF7"
              }
            },
            "background": {
              "solid": {
                "color": "#0B1020"
              }
            },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "selection": [
          {
            "selectAllCheckboxEnabled": true,
            "singleSelect": false
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": false,
            "gridHorizontal": true,
            "gridHorizontalColor": {
              "solid": {
                "color": "#1F2A44"
              }
            },
            "rowPadding": 4
          }
        ],
        "columnHeaders": [
          {
            "fontColor": {
              "solid": {
                "color": "#F8FAFC"
              }
            },
            "backColor": {
              "solid": {
                "color": "#111827"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 10
          }
        ],
        "values": [
          {
            "fontColor": {
              "solid": {
                "color": "#E6EDF7"
              }
            },
            "backColorPrimary": {
              "solid": {
                "color": "#0B1020"
              }
            },
            "backColorSecondary": {
              "solid": {
                "color": "#0F172A"
              }
            },
            "fontFamily": "Segoe UI",
            "fontSize": 9
          }
        ]
      }
    },
    "matrix": {
      "*": {
        "grid": [
          {
            "gridVertical": false,
            "gridHorizontal": true,
            "gridHorizontalColor": {
              "solid": {
                "color": "#1F2A44"
              }
            },
            "rowPadding": 4
          }
        ],
        "rowHeaders": [
          {
            "fontColor": {
              "solid": {
                "color": "#F8FAFC"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 10
          }
        ],
        "columnHeaders": [
          {
            "fontColor": {
              "solid": {
                "color": "#F8FAFC"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 10
          }
        ],
        "values": [
          {
            "fontColor": {
              "solid": {
                "color": "#E6EDF7"
              }
            },
            "fontFamily": "Segoe UI",
            "fontSize": 9
          }
        ]
      }
    }
  }
}