DIVIDE(
    SUMX(
        'mart_role_daily_performance',
        'mart_role_daily_performance'[avg_deaths]
            * 'mart_role_daily_performance'[matches_played]
    ),
    [Role Matches]
)

Role Avg Assists =
DIVIDE(
    SUMX(
        'mart_role_daily_performance',
        'mart_role_daily_performance'[avg_assists]
            * 'mart_role_daily_performance'[matches_played]
    ),
    [Role Matches]
)

Role Avg KDA =
DIVIDE(
    SUMX(
        'mart_role_daily_performance',
        'mart_role_daily_performance'[avg_kda]
            * 'mart_role_daily_performance'[matches_played]
    ),
    [Role Matches]
)

Role Avg Gold Earned =
DIVIDE(
    SUMX(
        'mart_role_daily_performance',
        'mart_role_daily_performance'[avg_gold_earned]
            * 'mart_role_daily_performance'[matches_played]
    ),
    [Role Matches]
)

Role Avg Damage To Champions =
DIVIDE(
    SUMX(
        'mart_role_daily_performance',
        'mart_role_daily_performance'[avg_damage_dealt_to_champions]
            * 'mart_role_daily_performance'[matches_played]
    ),
    [Role Matches]
)

Role Avg Damage Taken =
DIVIDE(
    SUMX(
        'mart_role_daily_performance',
        'mart_role_daily_performance'[avg_damage_taken]
            * 'mart_role_daily_performance'[matches_played]
    ),
    [Role Matches]
)

Role Avg Vision Score =
DIVIDE(
    SUMX(
        'mart_role_daily_performance',
        'mart_role_daily_performance'[avg_vision_score]
            * 'mart_role_daily_performance'[matches_played]
    ),
    [Role Matches]
)

Role Avg CS =
DIVIDE(
    SUMX(
        'mart_role_daily_performance',
        'mart_role_daily_performance'[avg_cs]
            * 'mart_role_daily_performance'[matches_played]
    ),
    [Role Matches]
)

-- Rank Snapshot

Rank Summary Players =
VAR RankFilter =
    SUMMARIZE(
        'dim_rank',
        'dim_rank'[queue],
        'dim_rank'[tier],
        'dim_rank'[rank]
    )
RETURN
    CALCULATE(
        SUM('mart_rank_daily_summary'[players]),
        TREATAS(
            RankFilter,
            'mart_rank_daily_summary'[queue],
            'mart_rank_daily_summary'[tier],
            'mart_rank_daily_summary'[rank]
        )
    )

Rank Population Share =
DIVIDE(
    [Rank Summary Players],
    CALCULATE([Rank Summary Players], ALL('dim_rank'))
)

Rank Avg League Points =
VAR RankFilter =
    SUMMARIZE(
        'dim_rank',
        'dim_rank'[queue],
        'dim_rank'[tier],
        'dim_rank'[rank]
    )
RETURN
    CALCULATE(
        DIVIDE(
            SUMX(
                'mart_rank_daily_summary',
                'mart_rank_daily_summary'[avg_league_points]
                    * 'mart_rank_daily_summary'[players]
            ),
            SUM('mart_rank_daily_summary'[players])
        ),
        TREATAS(
            RankFilter,
            'mart_rank_daily_summary'[queue],
            'mart_rank_daily_summary'[tier],
            'mart_rank_daily_summary'[rank]
        )
    )

Rank Avg Win Rate =
VAR RankFilter =
    SUMMARIZE(
        'dim_rank',
        'dim_rank'[queue],
        'dim_rank'[tier],
        'dim_rank'[rank]
    )
RETURN
    CALCULATE(
        DIVIDE(
            SUMX(
                'mart_rank_daily_summary',
                'mart_rank_daily_summary'[avg_win_rate]
                    * 'mart_rank_daily_summary'[players]
            ),
            SUM('mart_rank_daily_summary'[players])
        ),
        TREATAS(
            RankFilter,
            'mart_rank_daily_summary'[queue],
            'mart_rank_daily_summary'[tier],
            'mart_rank_daily_summary'[rank]
        )
    )

Rank Total Wins =
VAR RankFilter =
    SUMMARIZE(
        'dim_rank',
        'dim_rank'[queue],
        'dim_rank'[tier],
        'dim_rank'[rank]
    )
RETURN
    CALCULATE(
        SUM('mart_rank_daily_summary'[total_wins]),
        TREATAS(
            RankFilter,
            'mart_rank_daily_summary'[queue],
            'mart_rank_daily_summary'[tier],
            'mart_rank_daily_summary'[rank]
        )
    )

Rank Total Losses =
VAR RankFilter =
    SUMMARIZE(
        'dim_rank',
        'dim_rank'[queue],
        'dim_rank'[tier],
        'dim_rank'[rank]
    )
RETURN
    CALCULATE(
        SUM('mart_rank_daily_summary'[total_losses]),
        TREATAS(
            RankFilter,
            'mart_rank_daily_summary'[queue],
            'mart_rank_daily_summary'[tier],
            'mart_rank_daily_summary'[rank]
        )
    )

