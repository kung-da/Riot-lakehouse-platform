-- Riot Lakehouse Gold measures.
-- Paste these into Power BI Desktop after importing the Gold tables.
-- The measures reference only existing Gold tables and columns.

-- Shared / Executive

Matches =
DISTINCTCOUNT('dim_match'[match_id])

Participant Rows =
COUNTROWS('fact_participant_performance')

Unique Players =
DISTINCTCOUNT('fact_participant_performance'[puuid])

Unique Champions =
DISTINCTCOUNT('fact_participant_performance'[champion_id])

Participant Wins =
CALCULATE(
    [Participant Rows],
    'fact_participant_performance'[win] = TRUE()
)

Participant Win Rate =
DIVIDE([Participant Wins], [Participant Rows])

Total Kills =
SUM('fact_participant_performance'[kills])

Total Deaths =
SUM('fact_participant_performance'[deaths])

Total Assists =
SUM('fact_participant_performance'[assists])

KDA Ratio =
DIVIDE([Total Kills] + [Total Assists], [Total Deaths])

Avg KDA =
AVERAGE('fact_participant_performance'[kda])

Avg Gold Earned =
AVERAGE('fact_participant_performance'[gold_earned])

Avg Damage To Champions =
AVERAGE('fact_participant_performance'[total_damage_dealt_to_champions])

Avg Damage Taken =
AVERAGE('fact_participant_performance'[total_damage_taken])

Avg Vision Score =
AVERAGE('fact_participant_performance'[vision_score])

Avg CS =
AVERAGE('fact_participant_performance'[cs])

Avg Match Duration Minutes =
DIVIDE(AVERAGE('dim_match'[game_duration]), 60)

Selected Date Range =
VAR MinDate = MIN('dim_date'[game_date])
VAR MaxDate = MAX('dim_date'[game_date])
RETURN
    IF(
        ISBLANK(MinDate) || ISBLANK(MaxDate),
        "No date selected",
        FORMAT(MinDate, "yyyy-MM-dd") & " to " & FORMAT(MaxDate, "yyyy-MM-dd")
    )

-- Player Performance

Selected Player Label =
COALESCE(
    SELECTEDVALUE('dim_summoner'[riot_id_game_name]),
    SELECTEDVALUE('dim_summoner'[summoner_name]),
    SELECTEDVALUE('dim_summoner'[puuid]),
    "All players"
)

Player Matches =
SUM('mart_player_daily_performance'[matches_played])

Player Wins =
SUM('mart_player_daily_performance'[wins])

Player Losses =
SUM('mart_player_daily_performance'[losses])

Player Win Rate =
DIVIDE([Player Wins], [Player Matches])

Player Total Kills =
SUM('mart_player_daily_performance'[total_kills])

Player Total Deaths =
SUM('mart_player_daily_performance'[total_deaths])

Player Total Assists =
SUM('mart_player_daily_performance'[total_assists])

Player KDA Ratio =
DIVIDE([Player Total Kills] + [Player Total Assists], [Player Total Deaths])

Player Unique Champions =
SUM('mart_player_daily_performance'[unique_champions])

Player Avg Kills =
DIVIDE(
    SUMX(
        'mart_player_daily_performance',
        'mart_player_daily_performance'[avg_kills]
            * 'mart_player_daily_performance'[matches_played]
    ),
    [Player Matches]
)

Player Avg Deaths =
DIVIDE(
    SUMX(
        'mart_player_daily_performance',
        'mart_player_daily_performance'[avg_deaths]
            * 'mart_player_daily_performance'[matches_played]
    ),
    [Player Matches]
)

Player Avg Assists =
DIVIDE(
    SUMX(
        'mart_player_daily_performance',
        'mart_player_daily_performance'[avg_assists]
            * 'mart_player_daily_performance'[matches_played]
    ),
    [Player Matches]
)

Player Avg KDA =
DIVIDE(
    SUMX(
        'mart_player_daily_performance',
        'mart_player_daily_performance'[avg_kda]
            * 'mart_player_daily_performance'[matches_played]
    ),
    [Player Matches]
)

Player Avg Gold Earned =
DIVIDE(
    SUMX(
        'mart_player_daily_performance',
        'mart_player_daily_performance'[avg_gold_earned]
            * 'mart_player_daily_performance'[matches_played]
    ),
    [Player Matches]
)

Player Avg Damage To Champions =
DIVIDE(
    SUMX(
        'mart_player_daily_performance',
        'mart_player_daily_performance'[avg_damage_dealt_to_champions]
            * 'mart_player_daily_performance'[matches_played]
    ),
    [Player Matches]
)

Player Avg Damage Taken =
DIVIDE(
    SUMX(
        'mart_player_daily_performance',
        'mart_player_daily_performance'[avg_damage_taken]
            * 'mart_player_daily_performance'[matches_played]
    ),
    [Player Matches]
)

Player Avg Vision Score =
DIVIDE(
    SUMX(
        'mart_player_daily_performance',
        'mart_player_daily_performance'[avg_vision_score]
            * 'mart_player_daily_performance'[matches_played]
    ),
    [Player Matches]
)

Player Avg CS =
DIVIDE(
    SUMX(
        'mart_player_daily_performance',
        'mart_player_daily_performance'[avg_cs]
            * 'mart_player_daily_performance'[matches_played]
    ),
    [Player Matches]
)

-- Champion Meta

Champion Matches =
SUM('mart_champion_daily_performance'[matches_played])

Champion Unique Players =
SUM('mart_champion_daily_performance'[unique_players])

Champion Wins =
SUM('mart_champion_daily_performance'[wins])

Champion Losses =
SUM('mart_champion_daily_performance'[losses])

Champion Win Rate =
DIVIDE([Champion Wins], [Champion Matches])

Champion Pick Rate =
DIVIDE(
    [Champion Matches],
    CALCULATE([Champion Matches], ALL('dim_champion'))
)

Champion Total Kills =
SUM('mart_champion_daily_performance'[total_kills])

Champion Total Deaths =
SUM('mart_champion_daily_performance'[total_deaths])

Champion Total Assists =
SUM('mart_champion_daily_performance'[total_assists])

Champion Kill Share =
DIVIDE(
    [Champion Total Kills],
    CALCULATE([Champion Total Kills], ALL('dim_champion'))
)

Champion Avg Kills =
DIVIDE(
    SUMX(
        'mart_champion_daily_performance',
        'mart_champion_daily_performance'[avg_kills]
            * 'mart_champion_daily_performance'[matches_played]
    ),
    [Champion Matches]
)

Champion Avg Deaths =
DIVIDE(
    SUMX(
        'mart_champion_daily_performance',
        'mart_champion_daily_performance'[avg_deaths]
            * 'mart_champion_daily_performance'[matches_played]
    ),
    [Champion Matches]
)

Champion Avg Assists =
DIVIDE(
    SUMX(
        'mart_champion_daily_performance',
        'mart_champion_daily_performance'[avg_assists]
            * 'mart_champion_daily_performance'[matches_played]
    ),
    [Champion Matches]
)

Champion Avg KDA =
DIVIDE(
    SUMX(
        'mart_champion_daily_performance',
        'mart_champion_daily_performance'[avg_kda]
            * 'mart_champion_daily_performance'[matches_played]
    ),
    [Champion Matches]
)

Champion Avg Gold Earned =
DIVIDE(
    SUMX(
        'mart_champion_daily_performance',
        'mart_champion_daily_performance'[avg_gold_earned]
            * 'mart_champion_daily_performance'[matches_played]
    ),
    [Champion Matches]
)

Champion Avg Damage To Champions =
DIVIDE(
    SUMX(
        'mart_champion_daily_performance',
        'mart_champion_daily_performance'[avg_damage_dealt_to_champions]
            * 'mart_champion_daily_performance'[matches_played]
    ),
    [Champion Matches]
)

Champion Damage Share =
DIVIDE(
    SUMX(
        'mart_champion_daily_performance',
        'mart_champion_daily_performance'[avg_damage_dealt_to_champions]
            * 'mart_champion_daily_performance'[matches_played]
    ),
    CALCULATE(
        SUMX(
            'mart_champion_daily_performance',
            'mart_champion_daily_performance'[avg_damage_dealt_to_champions]
                * 'mart_champion_daily_performance'[matches_played]
        ),
        ALL('dim_champion')
    )
)

Champion Avg Damage Taken =
DIVIDE(
    SUMX(
        'mart_champion_daily_performance',
        'mart_champion_daily_performance'[avg_damage_taken]
            * 'mart_champion_daily_performance'[matches_played]
    ),
    [Champion Matches]
)

Champion Avg Vision Score =
DIVIDE(
    SUMX(
        'mart_champion_daily_performance',
        'mart_champion_daily_performance'[avg_vision_score]
            * 'mart_champion_daily_performance'[matches_played]
    ),
    [Champion Matches]
)

Champion Avg CS =
DIVIDE(
    SUMX(
        'mart_champion_daily_performance',
        'mart_champion_daily_performance'[avg_cs]
            * 'mart_champion_daily_performance'[matches_played]
    ),
    [Champion Matches]
)

Champion Meta Score =
VAR PickComponent = [Champion Pick Rate]
VAR WinComponent = [Champion Win Rate]
VAR KdaBaseline = CALCULATE([Champion Avg KDA], ALL('dim_champion'))
VAR KdaComponent = DIVIDE([Champion Avg KDA], KdaBaseline)
RETURN
    (PickComponent * 0.45)
        + (WinComponent * 0.35)
        + (KdaComponent * 0.20)

-- Role / Lane Analysis

Role Matches =
SUM('mart_role_daily_performance'[matches_played])

Role Unique Players =
SUM('mart_role_daily_performance'[unique_players])

Role Unique Champions =
SUM('mart_role_daily_performance'[unique_champions])

Role Wins =
SUM('mart_role_daily_performance'[wins])

Role Losses =
SUM('mart_role_daily_performance'[losses])

Role Win Rate =
DIVIDE([Role Wins], [Role Matches])

Role Pick Share =
DIVIDE(
    [Role Matches],
    CALCULATE([Role Matches], ALL('mart_role_daily_performance'[team_position]))
)

Role Avg Kills =
DIVIDE(
    SUMX(
        'mart_role_daily_performance',
        'mart_role_daily_performance'[avg_kills]
            * 'mart_role_daily_performance'[matches_played]
    ),
    [Role Matches]
)

