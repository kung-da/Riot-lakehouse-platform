Inactive Players =
VAR RankFilter =
    SUMMARIZE(
        'dim_rank',
        'dim_rank'[queue],
        'dim_rank'[tier],
        'dim_rank'[rank]
    )
RETURN
    CALCULATE(
        SUM('mart_rank_daily_summary'[inactive_players]),
        TREATAS(
            RankFilter,
            'mart_rank_daily_summary'[queue],
            'mart_rank_daily_summary'[tier],
            'mart_rank_daily_summary'[rank]
        )
    )

Rank Snapshot Unique Players =
VAR RankFilter =
    SUMMARIZE(
        'dim_rank',
        'dim_rank'[queue],
        'dim_rank'[tier],
        'dim_rank'[rank]
    )
RETURN
    CALCULATE(
        DISTINCTCOUNT('fact_rank_snapshot'[puuid]),
        TREATAS(
            RankFilter,
            'fact_rank_snapshot'[queue],
            'fact_rank_snapshot'[tier],
            'fact_rank_snapshot'[rank]
        )
    )

Average League Points =
VAR RankFilter =
    SUMMARIZE(
        'dim_rank',
        'dim_rank'[queue],
        'dim_rank'[tier],
        'dim_rank'[rank]
    )
RETURN
    CALCULATE(
        AVERAGE('fact_rank_snapshot'[league_points]),
        TREATAS(
            RankFilter,
            'fact_rank_snapshot'[queue],
            'fact_rank_snapshot'[tier],
            'fact_rank_snapshot'[rank]
        )
    )

Rank Snapshot Wins =
VAR RankFilter =
    SUMMARIZE(
        'dim_rank',
        'dim_rank'[queue],
        'dim_rank'[tier],
        'dim_rank'[rank]
    )
RETURN
    CALCULATE(
        SUM('fact_rank_snapshot'[wins]),
        TREATAS(
            RankFilter,
            'fact_rank_snapshot'[queue],
            'fact_rank_snapshot'[tier],
            'fact_rank_snapshot'[rank]
        )
    )

Rank Snapshot Losses =
VAR RankFilter =
    SUMMARIZE(
        'dim_rank',
        'dim_rank'[queue],
        'dim_rank'[tier],
        'dim_rank'[rank]
    )
RETURN
    CALCULATE(
        SUM('fact_rank_snapshot'[losses]),
        TREATAS(
            RankFilter,
            'fact_rank_snapshot'[queue],
            'fact_rank_snapshot'[tier],
            'fact_rank_snapshot'[rank]
        )
    )

Rank Snapshot Win Rate =
DIVIDE([Rank Snapshot Wins], [Rank Snapshot Wins] + [Rank Snapshot Losses])

Is Hot Streak Count =
CALCULATE(
    [Rank Snapshot Unique Players],
    'fact_rank_snapshot'[hot_streak] = TRUE()
)

Is Inactive Count =
CALCULATE(
    [Rank Snapshot Unique Players],
    'fact_rank_snapshot'[inactive] = TRUE()
)

-- Team Objectives

Team Objective Games =
SUM('mart_team_objective_daily_summary'[games_played])

Team Wins =
SUM('mart_team_objective_daily_summary'[wins])

Team Losses =
SUM('mart_team_objective_daily_summary'[losses])

Team Win Rate =
DIVIDE([Team Wins], [Team Objective Games])

Total Objective Score =
SUM('fact_team_objectives'[objective_score])

Team Objective Score =
[Total Objective Score]

Objective Rows =
COUNTROWS('fact_team_objectives')

Avg Objectives Per Team Game =
DIVIDE([Total Objective Score], [Objective Rows])

Avg Objective Score =
DIVIDE(
    SUMX(
        'mart_team_objective_daily_summary',
        'mart_team_objective_daily_summary'[avg_objective_score]
            * 'mart_team_objective_daily_summary'[games_played]
    ),
    [Team Objective Games]
)

Objective Control Share =
DIVIDE(
    [Total Objective Score],
    CALCULATE([Total Objective Score], ALL('dim_team'))
)

Total Baron Kills =
SUM('fact_team_objectives'[baron_kills])

Total Dragon Kills =
SUM('fact_team_objectives'[dragon_kills])

Total Rift Herald Kills =
SUM('fact_team_objectives'[rift_herald_kills])

Total Tower Kills =
SUM('fact_team_objectives'[tower_kills])

Total Inhibitor Kills =
SUM('fact_team_objectives'[inhibitor_kills])

Total Champion Kills =
SUM('fact_team_objectives'[champion_kills])

Avg Baron Kills =
DIVIDE(
    SUMX(
        'mart_team_objective_daily_summary',
        'mart_team_objective_daily_summary'[avg_baron_kills]
            * 'mart_team_objective_daily_summary'[games_played]
    ),
    [Team Objective Games]
)

Avg Dragon Kills =
DIVIDE(
    SUMX(
        'mart_team_objective_daily_summary',
        'mart_team_objective_daily_summary'[avg_dragon_kills]
            * 'mart_team_objective_daily_summary'[games_played]
    ),
    [Team Objective Games]
)

Avg Rift Herald Kills =
DIVIDE(
    SUMX(
        'mart_team_objective_daily_summary',
        'mart_team_objective_daily_summary'[avg_rift_herald_kills]
            * 'mart_team_objective_daily_summary'[games_played]
    ),
    [Team Objective Games]
)

Avg Tower Kills =
DIVIDE(
    SUMX(
        'mart_team_objective_daily_summary',
        'mart_team_objective_daily_summary'[avg_tower_kills]
            * 'mart_team_objective_daily_summary'[games_played]
    ),
    [Team Objective Games]
)

Avg Inhibitor Kills =
DIVIDE(
    SUMX(
        'mart_team_objective_daily_summary',
        'mart_team_objective_daily_summary'[avg_inhibitor_kills]
            * 'mart_team_objective_daily_summary'[games_played]
    ),
    [Team Objective Games]
)

Avg Champion Kills =
DIVIDE(
    SUMX(
        'mart_team_objective_daily_summary',
        'mart_team_objective_daily_summary'[avg_champion_kills]
            * 'mart_team_objective_daily_summary'[games_played]
    ),
    [Team Objective Games]
)

-- Timeline Events

Timeline Frames =
COUNTROWS('fact_timeline_frames')

Timeline Frame Event Count =
SUM('fact_timeline_frames'[event_count])

Timeline Events =
COUNTROWS('fact_timeline_events')

Timeline Event Match Count =
DISTINCTCOUNT('fact_timeline_events'[match_id])

Avg Events Per Match =
DIVIDE([Timeline Events], [Timeline Event Match Count])

Avg Events Per Frame =
DIVIDE([Timeline Events], [Timeline Frames])

Average Event Minute =
DIVIDE(AVERAGE('fact_timeline_events'[event_timestamp]), 60000)

Kill Events =
CALCULATE(
    [Timeline Events],
    'fact_timeline_events'[event_type] = "CHAMPION_KILL"
)

Elite Monster Events =
CALCULATE(
    [Timeline Events],
    'fact_timeline_events'[event_type] = "ELITE_MONSTER_KILL"
)

Building Events =
CALCULATE(
    [Timeline Events],
    'fact_timeline_events'[event_type] = "BUILDING_KILL"
)

Dragon Events =
CALCULATE(
    [Timeline Events],
    'fact_timeline_events'[monster_type] = "DRAGON"
)

Baron Events =
CALCULATE(
    [Timeline Events],
    'fact_timeline_events'[monster_type] = "BARON_NASHOR"
)

Rift Herald Events =
CALCULATE(
    [Timeline Events],
    'fact_timeline_events'[monster_type] = "RIFTHERALD"
)

Tower Events =
CALCULATE(
    [Timeline Events],
    'fact_timeline_events'[building_type] = "TOWER_BUILDING"
)

Inhibitor Events =
CALCULATE(
    [Timeline Events],
    'fact_timeline_events'[building_type] = "INHIBITOR_BUILDING"
)

Events Before 15 Minutes =
CALCULATE(
    [Timeline Events],
    'fact_timeline_events'[event_timestamp] <= 900000
)

Kills Before 15 Minutes =
CALCULATE(
    [Kill Events],
    'fact_timeline_events'[event_timestamp] <= 900000
)
