RIOT_API_KEY=

# Runtime selector. Use dev for local folders, prod for S3 paths in configs/prod.yaml.
LAKEHOUSE_ENV=dev
LAKEHOUSE_CONFIG_DIR=configs
# If you copy this file to .env.prod, change this value to .env.prod.
LAKEHOUSE_ENV_FILE=.env

# Local path overrides for configs/dev.yaml.
LAKEHOUSE_RAW_ROOT=raw
LAKEHOUSE_ROOT=data/lakehouse
LAKEHOUSE_CHECKPOINT_ROOT=metadata/checkpoints
LAKEHOUSE_REPORT_ROOT=reports

# AWS/S3 config for LAKEHOUSE_ENV=prod.
AWS_REGION=ap-southeast-1
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_S3_ENDPOINT_URL=
AWS_S3_PATH_STYLE_ACCESS=false
S3_BUCKET=
S3_RAW_PREFIX=raw
S3_LAKEHOUSE_PREFIX=lakehouse
S3_CHECKPOINT_PREFIX=metadata/checkpoints
S3_REPORT_PREFIX=reports
ATHENA_DATABASE=riot_lakehouse

# Spark knobs.
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=4g
SPARK_SHUFFLE_PARTITIONS=8
SPARK_DEFAULT_PARALLELISM=8
SPARK_ENABLE_DELTA=false
SPARK_INCLUDE_HADOOP_AWS_PACKAGE=true

# Airflow local UI.
AIRFLOW_UID=50000
AIRFLOW_PORT=8088
AIRFLOW__CORE__LOAD_EXAMPLES=false
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
