# Local data/runtime artifacts. Keep these on disk/S3, not in Git.
raw/**
!raw/**/
!raw/**/.gitkeep
data/**
!data/**/
!data/**/.gitkeep
reports/**
!reports/**/
!reports/**/.gitkeep
metadata/checkpoints/**
!metadata/checkpoints/
!metadata/checkpoints/.gitkeep

# Local runtime/config
.env
.venv/
__pycache__/
*.py[cod]
.pytest_cache/

# Lakehouse outputs are reproducible
metadata/airflow/

# Power BI local caches, settings, and binary exports
powerBI/**/.pbi/
powerBI/**/*.abf
powerBI/**/*.pbix
powerBI/**/*.pbit

# Spark/Airflow local noise
spark-warehouse/
metastore_db/
derby.log
logs/
