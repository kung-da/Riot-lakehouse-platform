# Local data/runtime artifacts: keep on disk/S3, not in Git.
raw/**
!raw/**/
!raw/**/.gitkeep
data/**
!data/**/
!data/**/.gitkeep
reports/**
!reports/**/
!reports/**/.gitkeep
metadata/**
!metadata/**/
!metadata/**/.gitkeep

# Local config/secrets.
.env
.env.*
!.env.example

# Python/runtime noise.
.venv/
__pycache__/
*.py[cod]
.pytest_cache/

# JS/frontend build noise.
node_modules/
dist/
build/

# Spark/Airflow local noise.
spark-warehouse/
metastore_db/
derby.log
logs/

# Lakehouse generated files.
*.parquet
*.snappy.parquet
*.crc
_SUCCESS

# Power BI local caches and binary exports.
powerBI/
powerBI/**/.pbi/
powerBI/**/*.abf
powerBI/**/*.pbix
powerBI/**/*.pbit

# Put tiny examples in samples/ when needed; docs/images stay tracked.
